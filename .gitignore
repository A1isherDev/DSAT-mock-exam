# ============================================================
# .gitignore — Root project level
# ============================================================

# ── Python / Django ────────────────────────────────────────────
backend/.env
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/db.sqlite3
backend/staticfiles/
backend/media/

# ── Node / Next.js ────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/.env
frontend/.env.local

# ── OS / Editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
