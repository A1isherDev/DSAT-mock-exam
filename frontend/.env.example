# Copy to .env.local for development

NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Telegram Login: bot username only (no @). Backend needs TELEGRAM_BOT_TOKEN.
# The button asks for phone + DM access when Telegram supports it; users can decline phone and still sign in.
NEXT_PUBLIC_TELEGRAM_BOT_NAME=

# Optional: full API base if not using same-origin /api proxy
# NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Console cross-linking / teacher-portal redirects.
# Defaults to the production hosts; override when testing locally
# (e.g. http://teacher.localhost:3000 and http://localhost:3000).
NEXT_PUBLIC_TEACHER_PORTAL_URL=https://teacher.mastersat.uz
NEXT_PUBLIC_MAIN_SITE_URL=https://mastersat.uz
